{
  "productName": "StarCore Kit",
  "version": "1.0.0",
  "identifier": "com.lol.starcorkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "星核刷机工具箱",
        "width": 1200,
        "height": 800,
        "transparent": true,
        "windowEffects": {
          "effects": ["blur"],
          "state": "active"
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"]
  }
}
